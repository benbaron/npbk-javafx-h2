        { "line": "", "label": "Total Assets", "valueKey": "balanceStmt.totalAssets", "format": "currency" },
        { "line": "", "label": "Total Liabilities", "valueKey": "balanceStmt.totalLiabilities", "format": "currency" },
        { "line": "", "label": "Net Income / (Loss)", "valueKey": "incomeStmt.netIncomeLoss", "format": "currency" }
      ]
